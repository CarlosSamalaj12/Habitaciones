# ============================================
# CONFIGURACION PARA PRODUCCION
# ============================================
# Copia este archivo como .env en server/
# y completa con tus datos reales de produccion
# ============================================

# ---- PUERTO DEL SERVIDOR ----
PORT=3000

# ---- BASE DE DATOS (MariaDB/MySQL) ----
# Si la BD esta en el mismo servidor, usa localhost
DB_HOST=localhost
# Si la BD esta en otro servidor, pon su IP
# DB_HOST=192.168.1.100

DB_PORT=3306
DB_USER=hk_user
DB_PASS=TU_CONTRASENA_AQUI
DB_NAME=bdinscamareria

# ---- SEGURIDAD (OBLIGATORIO) ----
# Cambia esto por una clave secreta unica y larga
# Puedes generarla con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=pon_aqui_una_clave_secreta_larga_y_unica

# ---- CORS (OBLIGATORIO) ----
# Lista de origenes permitidos separados por coma
# Ej: http://localhost:3000,https://tudominio.com,https://www.tudominio.com
ALLOWED_ORIGINS=http://localhost:3000,https://tudominio.com

# ---- AUTENTICACION ----
# 1 = requiere login, 0 = acceso libre (solo desarrollo)
REQUIRE_AUTH=1

# ---- NOTIFICACIONES PUSH (VAPID) ----
# Estas claves ya vienen por defecto en server.js
# Solo cambia el email si quieres uno real
VAPID_SUBJECT=mailto:sistemas@tudominio.com

# ---- MONDAY.COM (opcional, solo si usas Monday) ----
MONDAY_TOKEN=
MONDAY_BOARD_ID=0
